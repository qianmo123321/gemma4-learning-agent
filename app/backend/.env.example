# ===== API server =====
APP_NAME=Gemma4 Private Learning Agent API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ===== Model provider =====
# openai_compatible: 推荐，调用 A100 上 vLLM 的 OpenAI-compatible API
# ollama: 可选，调用本机 Ollama
# mock: 前后端联调，不调用真实模型
MODEL_PROVIDER=openai_compatible

# A100 同机 vLLM 默认地址
VLLM_BASE_URL=http://127.0.0.1:8001/v1
VLLM_API_KEY=EMPTY
# 基座推理时可写 google/gemma-4-12b-it；挂载 LoRA 后写 gemma4-learning
VLLM_MODEL=google/gemma-4-12b-it

# Ollama 备用
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b

# ===== RAG =====
RAG_TOP_K_DEFAULT=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=90
MAX_UPLOAD_MB=30

# ===== Paths =====
KNOWLEDGE_DIR=/opt/gemma4_learning_agent/backend/data/knowledge
RAG_INDEX_PATH=/opt/gemma4_learning_agent/backend/data/hybrid_rag.joblib
CHAT_LOG_PATH=/opt/gemma4_learning_agent/backend/data/qa_history.jsonl
FEEDBACK_LOG_PATH=/opt/gemma4_learning_agent/backend/data/feedback.jsonl
